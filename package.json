{
  "name": "pydata_sphinx_theme",
  "repository": "https://github.com/pydata/pydata-sphinx-theme",
  "scripts": {
    "build": "webpack --mode=production",
    "build-dev": "webpack",
    "profile": "webpack --profile --json > bundle-stats.json",
    "view-profile": "webpack-bundle-analyzer bundle-stats.json",
    "prettier:files": "prettier --write \"**/*{.ts,.tsx,.js,.jsx,.css,.scss,.json,.md}\"",
    "prettier:check": "prettier --check \"**/*{.ts,.tsx,.js,.jsx,.css,.scss,.json,.md}\"",
    "stylelint:check": "stylelint \"src/**/*.scss\"",
    "stylelint:files": "stylelint --fix"
  },
  "devDependencies": {
    "axe-core": "^4.6.3",
    "css-loader": "^6.8.1",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "dedent": "^0.7.0",
    "html-webpack-plugin": "^5.0.0",
    "imports-loader": "^0.8.0",
    "mini-css-extract-plugin": "^2.7.5",
    "prettier": "^3.8.3",
    "resolve-url-loader": "^5.0.0",
    "sass": "^1.59.3",
    "sass-loader": "^10.3.1",
    "style-loader": "^4.0.0",
    "stylelint": "^16.26.1",
    "stylelint-config-standard-scss": "^16.0.0",
    "stylelint-prettier": "^4.1.0",
    "terser-webpack-plugin": "^5.4.0",
    "webpack": "^5.105.1",
    "webpack-cli": "^5.0.0"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@popperjs/core": "^2.11.6",
    "bootstrap": "^5.2.2",
    "compare-versions": "^5.0.3",
    "webpack-bundle-analyzer": "^4.10.2"
  }
}
